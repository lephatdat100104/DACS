@model List<DACS.Models.ChatHistory>
@{
    ViewData["Title"] = "Lịch sử tất cả người dùng";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">
    <h2 class="text-center mb-4">📜 Lịch sử trò chuyện của tất cả người dùng</h2>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover table-bordered align-middle">
                <thead class="table-primary text-center">
                    <tr>
                        <th style="width: 15%;">🕒 Thời gian</th>
                        <th style="width: 20%;">👤 Email người dùng</th>
                        <th style="width: 30%;">❓ Câu hỏi</th>
                        <th>💬 Câu trả lời</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Timestamp.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.User?.Email</td>
                            <td>@item.Question</td>
                            <td>@item.Answer</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-warning text-center">
            Không có lịch sử trò chuyện nào được ghi nhận.
        </div>
    }
</div>
