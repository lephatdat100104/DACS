@model List<DACS.Models.ChatHistory>

@{
    ViewData["Title"] = "Chatbot";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --primary-color: #007bff; /* Chatbot primary color (blue) */
        --user-message-bg: #e2e6ea; /* Light gray for user messages */
        --bot-message-bg: #dcf8c6; /* Light green for bot messages */
        --text-color: #333;
        --bg-color: #f0f2f5; /* App background */
        --chat-input-bg: #fff;
        --header-bg: #fff;
    }

    body {
        background-color: var(--bg-color);
        font-family: 'Poppins', sans-serif;
    }

    .chat-page {
        display: flex;
        flex-direction: column;
        height: 85vh; /* Chiều cao chiếm gần hết màn hình */
        max-width: 900px;
        margin: 40px auto;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .chat-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px 25px;
        background-color: var(--header-bg);
        border-bottom: 1px solid #dee2e6;
    }

        .chat-header h2 {
            margin: 0;
            font-weight: 600;
            color: var(--primary-color);
        }

    .chat-window {
        flex-grow: 1;
        padding: 25px;
        overflow-y: auto;
        background-color: var(--bg-color);
        display: flex;
        flex-direction: column;
    }

        /* Custom Scrollbar */
        .chat-window::-webkit-scrollbar {
            width: 8px;
        }

        .chat-window::-webkit-scrollbar-thumb {
            background-color: rgba(0,0,0,0.15);
            border-radius: 4px;
        }

    .message-container {
        margin-bottom: 15px;
        display: flex;
        flex-direction: column;
    }

    .message {
        padding: 12px 20px;
        border-radius: 20px;
        max-width: 80%;
        line-height: 1.5;
        box-shadow: 0 2px 5px rgba(0,0,0,0.08);
        word-wrap: break-word;
    }

    .user-message {
        background-color: var(--user-message-bg);
        color: var(--text-color);
        align-self: flex-end;
        border-bottom-right-radius: 5px;
    }

    .bot-message {
        background-color: var(--bot-message-bg);
        color: var(--text-color);
        align-self: flex-start;
        border-bottom-left-radius: 5px;
    }

    .message-time {
        font-size: 0.8rem;
        color: #999;
        margin-top: 5px;
    }

    .user-message-container .message-time {
        text-align: right;
    }

    .bot-message-container .message-time {
        text-align: left;
    }

    .chat-input {
        padding: 15px 25px;
        background-color: var(--chat-input-bg);
        border-top: 1px solid #dee2e6;
        display: flex;
        align-items: center;
    }

        .chat-input .form-control {
            border-radius: 25px;
            padding: 10px 20px;
            border: 1px solid #e9ecef;
            background-color: #f8f9fa;
            transition: all 0.3s ease;
        }

            .chat-input .form-control:focus {
                border-color: var(--primary-color);
                box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
            }

        .chat-input .btn-send {
            background-color: var(--primary-color);
            border: none;
            border-radius: 50%;
            width: 45px;
            height: 45px;
            margin-left: 10px;
            color: #fff;
            transition: all 0.3s ease;
            display: flex;
            justify-content: center;
            align-items: center;
        }

            .chat-input .btn-send:hover {
                background-color: #0056b3;
                transform: scale(1.05);
            }
</style>

<div class="chat-page">
    <div class="chat-header">
        <h2>🤖 Chatbot Tư Vấn</h2>
        <a asp-controller="Chat" asp-action="History" class="btn btn-outline-secondary">
            <i class="bi bi-clock-history me-2"></i> Lịch sử chat
        </a>
    </div>

    <div class="chat-window" id="chatWindow">
        @foreach (var chat in Model)
        {
            <div class="message-container user-message-container">
                <div class="message user-message">@chat.Question</div>
                <span class="message-time">@chat.Timestamp.ToString("HH:mm")</span>
            </div>

            <div class="message-container bot-message-container">
                <div class="message bot-message">@chat.Answer</div>
                <span class="message-time">@chat.Timestamp.ToString("HH:mm")</span>
            </div>
        }
    </div>

    <div class="chat-input">
        <input type="text" id="messageInput" class="form-control" placeholder="Nhập câu hỏi của bạn..." />
        <button class="btn btn-send" onclick="sendMessage()">
            <i class="bi bi-send-fill"></i>
        </button>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const chatWindow = document.getElementById("chatWindow");
            chatWindow.scrollTop = chatWindow.scrollHeight;
        });

        async function sendMessage() {
            const messageInput = document.getElementById("messageInput");
            const message = messageInput.value.trim();
            if (!message) return;

            // Hiển thị tin nhắn của người dùng ngay lập tức
            const chatWindow = document.getElementById("chatWindow");
            const timestamp = new Date().toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });

            chatWindow.innerHTML += `
                <div class="message-container user-message-container">
                    <div class="message user-message">${message}</div>
                    <span class="message-time">${timestamp}</span>
                </div>
            `;
            chatWindow.scrollTop = chatWindow.scrollHeight;
            messageInput.value = "";
            messageInput.disabled = true; // Vô hiệu hóa input trong khi chờ phản hồi

            const response = await fetch('/Chat/SendMessage', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message })
            });

            const reply = await response.text();

            // Hiển thị tin nhắn của chatbot
            chatWindow.innerHTML += `
                <div class="message-container bot-message-container">
                    <div class="message bot-message">${reply}</div>
                    <span class="message-time">${timestamp}</span>
                </div>
            `;

            chatWindow.scrollTop = chatWindow.scrollHeight;
            messageInput.disabled = false; // Bật lại input
            messageInput.focus();
        }

        document.getElementById("messageInput").addEventListener("keydown", function(event) {
            if (event.key === "Enter") {
                event.preventDefault();
                sendMessage();
            }
        });
    </script>
}