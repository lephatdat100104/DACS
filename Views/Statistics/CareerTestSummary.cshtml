@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Thống kê trắc nghiệm nghề nghiệp";
    var labels = Model.Select(m => m.Type).ToArray();
    var counts = Model.Select(m => m.Count).ToArray();
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-gradient bg-primary text-white text-center py-3 rounded-top">
                    <h4 class="mb-0">
                        <i class="bi bi-bar-chart-line-fill me-2"></i>
                        Thống kê loại nghề nghiệp phổ biến
                    </h4>
                </div>
                <div class="card-body bg-light">
                    <canvas id="careerChart" height="300"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>
<a href="/Statistics/ExportCareerStatsToExcel" class="btn btn-success mb-3">
    <i class="bi bi-file-earmark-excel"></i> Xuất Excel
</a>
<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const ctx = document.getElementById('careerChart').getContext('2d');
    const careerChart = new Chart(ctx, {
        type: 'doughnut', // dùng doughnut để nhìn hiện đại hơn
        data: {
            labels: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(labels)),
            datasets: [{
                label: 'Số lượng sinh viên',
                data: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(counts)),
                backgroundColor: [
                    '#4e73df', '#1cc88a', '#36b9cc', '#f6c23e', '#e74a3b', '#858796'
                ],
                borderColor: '#fff',
                borderWidth: 2,
                hoverOffset: 15
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        color: '#333',
                        font: {
                            size: 14
                        }
                    }
                },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            return `${context.label}: ${context.raw} sinh viên`;
                        }
                    }
                }
            }
        }
    });
</script>

<!-- Bootstrap icons (optional for icons) -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
