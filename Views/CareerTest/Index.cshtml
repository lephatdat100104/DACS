@model DACS.Models.ViewModels.CareerTestViewModel

@{
    ViewData["Title"] = "Bài Test Định Hướng Nghề Nghiệp";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --primary-color: #4CAF50; /* Green */
        --secondary-color: #007bff; /* Blue */
        --text-color: #333;
        --bg-color: #f0f2f5;
        --card-bg: #fff;
        --shadow-light: rgba(0, 0, 0, 0.1);
    }

    body {
        background-color: var(--bg-color);
        font-family: 'Poppins', sans-serif;
    }

    .test-wrapper {
        max-width: 900px;
        margin: 50px auto;
        padding: 40px;
        background-color: var(--card-bg);
        border-radius: 25px;
        box-shadow: 0 15px 40px var(--shadow-light);
    }

    .test-header {
        text-align: center;
        margin-bottom: 40px;
    }

        .test-header h2 {
            font-weight: 700;
            color: var(--text-color);
            position: relative;
            display: inline-block;
        }

            .test-header h2::after {
                content: '';
                display: block;
                width: 60%;
                height: 4px;
                background-color: var(--primary-color);
                margin: 8px auto 0;
                border-radius: 2px;
            }

    .progress-section {
        display: flex;
        align-items: center;
        margin-bottom: 30px;
    }

    .progress-bar-container {
        flex-grow: 1;
        height: 8px;
        background-color: #e9ecef;
        border-radius: 4px;
        margin: 0 15px;
        overflow: hidden;
    }

    .progress-bar-fill {
        height: 100%;
        background-color: var(--primary-color);
        transition: width 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        border-radius: 4px;
    }

    .progress-text {
        font-weight: 600;
        color: var(--secondary-color);
        min-width: 60px;
        text-align: right;
    }

    .question-card {
        padding: 30px;
        background-color: var(--bg-color);
        border-radius: 15px;
        border: 1px solid #dee2e6;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .question-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        }

    .question-content {
        font-size: 1.4rem;
        font-weight: 600;
        color: var(--text-color);
        margin-bottom: 25px;
    }

    .option-list {
        list-style: none;
        padding: 0;
    }

    .option-item {
        margin-bottom: 12px;
    }

    .custom-radio {
        display: flex;
        align-items: center;
        padding: 15px 20px;
        background-color: var(--card-bg);
        border: 2px solid #ced4da;
        border-radius: 10px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .custom-radio:hover {
            background-color: #e9ecef;
            border-color: var(--secondary-color);
        }

        .custom-radio.selected {
            background-color: #d4edda;
            border-color: var(--primary-color);
            box-shadow: 0 0 10px rgba(76, 175, 80, 0.2);
        }

        .custom-radio input[type="radio"] {
            opacity: 0;
            position: absolute;
        }

        .custom-radio .label-text {
            font-size: 1.1rem;
            font-weight: 500;
            color: var(--text-color);
            flex-grow: 1;
            transition: color 0.2s;
        }

        .custom-radio .radio-indicator {
            width: 22px;
            height: 22px;
            border: 2px solid #ced4da;
            border-radius: 50%;
            position: relative;
            margin-right: 15px;
            transition: all 0.2s ease;
        }

        .custom-radio.selected .radio-indicator {
            border-color: var(--primary-color);
            background-color: var(--primary-color);
        }

            .custom-radio.selected .radio-indicator::after {
                content: '';
                width: 10px;
                height: 10px;
                background-color: var(--card-bg);
                border-radius: 50%;
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
            }

    .submit-button {
        padding: 15px 40px;
        font-size: 1.2rem;
        font-weight: bold;
        border-radius: 50px;
        background-color: var(--primary-color);
        border: none;
        color: #fff;
        box-shadow: 0 8px 20px rgba(76, 175, 80, 0.3);
        transition: all 0.3s ease;
    }

        .submit-button:hover {
            background-color: #45a049;
            box-shadow: 0 12px 30px rgba(76, 175, 80, 0.4);
            transform: translateY(-3px);
        }

    .btn-custom {
        padding: 12px 30px;
        font-size: 1.1rem;
        font-weight: bold;
        border-radius: 50px;
        transition: all 0.3s ease;
    }

    .btn-prev {
        background-color: #6c757d; /* Gray */
        border-color: #6c757d;
        color: #fff;
    }

        .btn-prev:hover {
            background-color: #5a6268;
            border-color: #545b62;
        }

    .btn-next {
        background-color: var(--secondary-color);
        border-color: var(--secondary-color);
        color: #fff;
    }

        .btn-next:hover {
            background-color: #0056b3;
            border-color: #004085;
        }
</style>

<div class="test-wrapper">
    <div class="test-header">
        <h2>Bài Test Định Hướng Nghề Nghiệp</h2>
    </div>

    <div class="progress-section">
        <h5 class="mb-0 text-muted">Câu hỏi <span id="currentQuestion">1</span> / <span id="totalQuestions">@Model.Questions.Count</span></h5>
        <div class="progress-bar-container">
            <div class="progress-bar-fill" id="progressBarFill" style="width: 0%;"></div>
        </div>
        <span class="progress-text" id="progressPercentage">0%</span>
    </div>

    <form asp-action="Submit" method="post">
        <div id="questionContainer">
        </div>

        <div class="d-flex justify-content-between mt-5">
            <button type="button" class="btn btn-custom btn-prev" id="prevButton" style="display: none;">
                <i class="bi bi-arrow-left"></i> Quay lại
            </button>
            <button type="button" class="btn btn-custom btn-next ms-auto" id="nextButton">
                Tiếp theo <i class="bi bi-arrow-right"></i>
            </button>
            <button type="submit" class="btn submit-button btn-lg w-100" id="submitButton" style="display: none;">
                <i class="bi bi-check-circle"></i> Gửi kết quả
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Khắc phục lỗi JsonException bằng cách tạo lại mảng câu hỏi
            const questions = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Questions.Select(q => new
            {
                Id = q.Id,
                Content = q.Content,
                Options = q.Options.Select(o => new
                {
                    Id = o.Id,
                    Text = o.Text
                })
            })));

            let currentQuestionIndex = 0;
            const totalQuestions = questions.length;
            const questionContainer = document.getElementById('questionContainer');
            const progressBarFill = document.getElementById('progressBarFill');
            const progressPercentage = document.getElementById('progressPercentage');
            const currentQuestionSpan = document.getElementById('currentQuestion');
            const nextButton = document.getElementById('nextButton');
            const prevButton = document.getElementById('prevButton');
            const submitButton = document.getElementById('submitButton');
            const form = document.querySelector('form');
            let userAnswers = {};

            renderQuestion(currentQuestionIndex);
            updateProgressBar();

            nextButton.addEventListener('click', function () {
                const selectedOption = isOptionSelected();
                if (!selectedOption) {
                    alert('Vui lòng chọn một đáp án để tiếp tục!');
                    return;
                }

                const currentQuestionId = questions[currentQuestionIndex].Id;
                userAnswers[currentQuestionId] = selectedOption.value;

                currentQuestionIndex++;
                if (currentQuestionIndex < totalQuestions) {
                    renderQuestion(currentQuestionIndex);
                    updateProgressBar();
                }
            });

            prevButton.addEventListener('click', function () {
                const selectedOption = isOptionSelected();
                if (selectedOption) {
                    const currentQuestionId = questions[currentQuestionIndex].Id;
                    userAnswers[currentQuestionId] = selectedOption.value;
                }

                if (currentQuestionIndex > 0) {
                    currentQuestionIndex--;
                    renderQuestion(currentQuestionIndex);
                    updateProgressBar();
                }
            });

            function renderQuestion(index) {
                questionContainer.innerHTML = '';
                const q = questions[index];

                const questionCard = document.createElement('div');
                questionCard.classList.add('question-card');

                const questionTitle = document.createElement('p');
                questionTitle.classList.add('question-content');
                questionTitle.innerHTML = `<strong>${index + 1}. ${q.Content}</strong>`;
                questionCard.appendChild(questionTitle);

                const optionList = document.createElement('ul');
                optionList.classList.add('option-list');
                const savedAnswer = userAnswers[q.Id];

                q.Options.forEach(opt => {
                    const optionItem = document.createElement('li');
                    optionItem.classList.add('option-item');
                    const label = document.createElement('label');
                    label.classList.add('custom-radio');
                    if (savedAnswer && savedAnswer == opt.Id) {
                        label.classList.add('selected');
                    }
                    label.innerHTML = `
                        <input type="radio" name="answers[${q.Id}]" value="${opt.Id}" ${savedAnswer && savedAnswer == opt.Id ? 'checked' : ''} required />
                        <span class="radio-indicator"></span>
                        <span class="label-text">${opt.Text}</span>
                    `;
                    optionItem.appendChild(label);
                    optionList.appendChild(optionItem);
                });
                questionCard.appendChild(optionList);

                questionContainer.appendChild(questionCard);

                document.querySelectorAll('.custom-radio').forEach(label => {
                    label.addEventListener('click', function() {
                        const parent = this.closest('.option-list');
                        parent.querySelectorAll('.custom-radio').forEach(otherLabel => otherLabel.classList.remove('selected'));
                        this.classList.add('selected');
                        this.querySelector('input').checked = true;
                    });
                });

                updateNavigationButtons();
            }

            function updateProgressBar() {
                const progress = (currentQuestionIndex / totalQuestions) * 100;
                progressBarFill.style.width = `${progress}%`;
                progressPercentage.innerText = `${Math.round(progress)}%`;
                currentQuestionSpan.innerText = currentQuestionIndex + 1;
            }

            function updateNavigationButtons() {
                if (currentQuestionIndex === 0) {
                    prevButton.style.display = 'none';
                    nextButton.classList.remove('ms-auto');
                } else {
                    prevButton.style.display = 'inline-block';
                    nextButton.classList.add('ms-auto');
                }

                if (currentQuestionIndex === totalQuestions - 1) {
                    nextButton.style.display = 'none';
                    submitButton.style.display = 'inline-block';
                } else {
                    nextButton.style.display = 'inline-block';
                    submitButton.style.display = 'none';
                }
            }

            function isOptionSelected() {
                const radioButtons = document.querySelectorAll(`input[name="answers[${questions[currentQuestionIndex].Id}]"]`);
                for (const radio of radioButtons) {
                    if (radio.checked) {
                        return radio;
                    }
                }
                return null;
            }
        });
    </script>
}