@model DACS.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Nền full màn hình -->
<div class="d-flex justify-content-center align-items-center min-vh-100"
     style="background: url('@Url.Content("~/img/anh5.jpg")') no-repeat center center/cover;">



    <!-- Form Glassmorphism -->
    <div class="p-5 shadow-lg"
         style="width: 100%; max-width: 420px;
                background: rgba(255, 255, 255, 0.15);
                backdrop-filter: blur(15px);
                border-radius: 20px;
                border: 1px solid rgba(255, 255, 255, 0.3);
                color: white;">

        <h2 class="text-center mb-4 fw-bold" style="font-size: 2rem;">
            🔐 Đăng nhập
        </h2>

        <form asp-action="Login" method="post">
            <!-- Email -->
            <div class="mb-4">
                <label asp-for="Email" class="form-label fw-semibold">📧 Email</label>
                <input asp-for="Email" class="form-control form-control-lg bg-transparent text-white border-white" placeholder="Nhập email" />
                <span asp-validation-for="Email" class="text-warning small"></span>
            </div>

            <!-- Password -->
            <div class="mb-4">
                <label asp-for="Password" class="form-label fw-semibold">🔑 Mật khẩu</label>
                <input asp-for="Password" class="form-control form-control-lg bg-transparent text-white border-white" type="password" placeholder="Nhập mật khẩu" />
                <span asp-validation-for="Password" class="text-warning small"></span>
            </div>

            <!-- Nút đăng nhập -->
            <button type="submit"
                    class="btn w-100 py-3 fw-bold shadow-sm"
                    style="background: linear-gradient(90deg, #00d4ff, #2c7be5); font-size: 1.2rem; border-radius: 10px; color: white;">
                Đăng nhập
            </button>
        </form>

        <!-- Link đăng ký -->
        <div class="mt-4 text-center">
            <span>Chưa có tài khoản?</span>
            <a asp-controller="Account" asp-action="Register" class="fw-semibold text-decoration-none" style="color: #00d4ff;">
                Đăng ký ngay
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
